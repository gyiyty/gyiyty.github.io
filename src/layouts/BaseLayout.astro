---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import { siteConfig } from "../lib/site";

type Props = {
  title?: string;
  description?: string;
  image?: string;
  bodyClass?: string;
};

const {
  title = siteConfig.siteTitle,
  description = siteConfig.siteDescription,
  image = "/wallpaper/hero-home.webp",
  bodyClass = ""
} = Astro.props;
const pageTitle = title === siteConfig.siteTitle ? title : `${title} | ${siteConfig.siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={image} />
    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.siteTitle} RSS`} href="/rss.xml" />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">跳到正文</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label={`${siteConfig.siteTitle} 首页`}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span>{siteConfig.siteTitle}</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <a href="/notes/">文章</a>
        <a href="/tags/">Tags</a>
        <a href="/search/">搜索</a>
        <a href="/about/">关于</a>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
