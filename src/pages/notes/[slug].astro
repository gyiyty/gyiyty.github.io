---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { displayTag, formatDate, makeTagSlug, publicNotes, sortByDateDesc } from "../../lib/site";

export async function getStaticPaths() {
  const notes = publicNotes(await getCollection("notes"));
  return notes.map((note) => ({ params: { slug: note.slug }, props: { note } }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);
const notes = sortByDateDesc(publicNotes(await getCollection("notes")));
const index = notes.findIndex((item) => item.slug === note.slug);
const previous = index >= 0 ? notes[index + 1] : undefined;
const next = index > 0 ? notes[index - 1] : undefined;
---

<BaseLayout title={note.data.title} description={note.data.description ?? note.data.title} image="/wallpaper/hero-note.webp">
  <article>
    <header class="note-hero">
      <picture>
        <source srcset="/wallpaper/hero-note-mobile.webp" media="(max-width: 760px)" />
        <img src="/wallpaper/hero-note.webp" alt="" aria-hidden="true" />
      </picture>
      <div class="hero-overlay"></div>
      <div class="note-hero-content">
        <p class="eyebrow">Note</p>
        <h1>{note.data.title}</h1>
        <div class="note-meta">
          {note.data.date && <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>}
          {note.data.sourcePath && <span>{note.data.sourcePath}</span>}
        </div>
        <div class="tag-row">
          {note.data.tags.map((tag) => (
            <a href={`/tags/${makeTagSlug(tag)}/`}>#{displayTag(tag)}</a>
          ))}
        </div>
      </div>
    </header>

    <div class="article-shell">
      {
        headings.length > 1 && (
          <aside class="toc" aria-label="文章目录">
            <strong>目录</strong>
            <nav>
              {headings
                .filter((heading) => heading.depth >= 2 && heading.depth <= 3)
                .map((heading) => (
                  <a class={`toc-depth-${heading.depth}`} href={`#${heading.slug}`} data-toc-link={heading.slug}>
                    {heading.text}
                  </a>
                ))}
            </nav>
          </aside>
        )
      }
      <div class="prose">
        <Content />
      </div>
    </div>

    <nav class="note-pagination" aria-label="文章翻页">
      {previous ? <a href={`/notes/${previous.slug}/`}><span>上一篇</span>{previous.data.title}</a> : <span></span>}
      {next ? <a href={`/notes/${next.slug}/`}><span>下一篇</span>{next.data.title}</a> : <span></span>}
    </nav>
  </article>

  <script>
    type TocItem = { id: string; heading: HTMLElement; link: HTMLAnchorElement };

    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"));
    const headings = tocLinks.reduce<TocItem[]>((items, link) => {
        const id = link.getAttribute("data-toc-link");
        const heading = id ? document.getElementById(id) : null;
        if (id && heading instanceof HTMLElement) {
          items.push({ id, heading, link });
        }
        return items;
      }, []);

    function setActiveToc(id: string) {
      for (const item of headings) {
        const isActive = item.id === id;
        item.link.classList.toggle("is-active", isActive);
        if (isActive) {
          item.link.setAttribute("aria-current", "location");
        } else {
          item.link.removeAttribute("aria-current");
        }
      }
    }

    function updateActiveToc() {
      if (headings.length === 0) return;

      const readLine = window.innerHeight * 0.28;
      let active = headings[0];
      for (const item of headings) {
        if (item.heading.getBoundingClientRect().top <= readLine) {
          active = item;
        } else {
          break;
        }
      }
      setActiveToc(active.id);
    }

    if (headings.length > 0) {
      let lockedTocId: string | null = null;
      let unlockTimer: number | undefined;

      function hasHeading(id: string) {
        return headings.some((item) => item.id === id);
      }

      function lockToc(id: string) {
        if (!hasHeading(id)) return;
        lockedTocId = id;
        setActiveToc(id);
        window.clearTimeout(unlockTimer);
        unlockTimer = window.setTimeout(() => {
          lockedTocId = null;
          updateActiveToc();
        }, 900);
      }

      function unlockForManualReading() {
        if (!lockedTocId) return;
        window.clearTimeout(unlockTimer);
        lockedTocId = null;
        updateActiveToc();
      }

      const initialId = decodeURIComponent(window.location.hash.slice(1));
      if (initialId && hasHeading(initialId)) {
        setActiveToc(initialId);
      } else {
        updateActiveToc();
      }

      for (const item of headings) {
        item.link.addEventListener("click", () => lockToc(item.id));
      }

      let ticking = false;
      window.addEventListener(
        "scroll",
        () => {
          if (lockedTocId) return;
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(() => {
            updateActiveToc();
            ticking = false;
          });
        },
        { passive: true }
      );

      window.addEventListener("wheel", unlockForManualReading, { passive: true });
      window.addEventListener("touchmove", unlockForManualReading, { passive: true });
      window.addEventListener("keydown", (event) => {
        if (["ArrowDown", "ArrowUp", "PageDown", "PageUp", "Home", "End", " "].includes(event.key)) {
          unlockForManualReading();
        }
      });

      window.addEventListener("hashchange", () => {
        const id = decodeURIComponent(window.location.hash.slice(1));
        if (id) lockToc(id);
      });
    }
  </script>
</BaseLayout>
