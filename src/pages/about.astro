---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/site";

const about = siteConfig.about;
const pageDescription = about.intro || `关于 ${siteConfig.authorName} 和这个知识网站。`;
const pageImage = about.gallery?.[0]?.src || "/wallpaper/about-band.webp";
const aboutMeta = (about.meta ?? []) as { label: string; value: string }[];
---

<BaseLayout title="关于" description={pageDescription} image={pageImage}>
  <section class="about-hero">
    <div class="about-content">
      <p class="eyebrow">{about.eyebrow}</p>
      <h1>{about.title || siteConfig.authorName}</h1>
      <p>{about.intro}</p>
      {
        aboutMeta.length > 0 && (
          <dl class="about-meta" aria-label="作者信息">
            {aboutMeta.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))}
          </dl>
        )
      }
    </div>
    {
      about.gallery?.length > 0 && (
        <div class="about-gallery" aria-label="作者图片">
          {about.gallery.map((image) => (
            <figure>
              <img src={image.src} alt={image.alt} loading="lazy" />
              {image.caption && <figcaption>{image.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )
    }
  </section>

  {
    about.sections?.length > 0 && (
      <section class="content-wrap about-grid" aria-label="作者档案">
        {about.sections.map((section) => (
          <div>
            <p class="eyebrow">{section.eyebrow}</p>
            <h2>{section.title}</h2>
            <p>{section.body}</p>
          </div>
        ))}
      </section>
    )
  }
</BaseLayout>
